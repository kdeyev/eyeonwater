        }
      }
    }
  },
  "entity": {
    "sensor": {
      "water_cost": {
        "name": "Water Cost"
      }
    },
    "binary_sensor": {
      "leak": {
        "name": "Leak Sensor"
      },
      "emptypipe": {
        "name": "Empty Pipe"
      },
      "tamper": {
        "name": "Tamper"
      },
      "coverremoved": {
        "name": "Cover Removed"
      },
      "reverseflow": {
        "name": "Reverse Waterflow"
      }
    }
  }
